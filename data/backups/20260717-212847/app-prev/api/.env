JWT_SECRET="Ifcy4Qd3kecYys7pquukvYYoQM9RV6d0G5XMOvH3Fyg"
# DuraciÃ³n del access token (por defecto 24h). Ej: 12h, 7d
# JWT_EXPIRES_IN=24h

# SaaS: clave para POST /platform/restaurantes (alta de tenants). VacÃ­o = deshabilitado.
# PLATFORM_PROVISION_KEY="genera-un-secreto-largo"

# App mÃ³vil SaaS: EXPO_PUBLIC_MULTI_TENANT=1 muestra campo "cÃ³digo del restaurante" en login.

# OrÃ­genes CORS permitidos (coma-separados). VacÃ­o = LAN abierta (tablets por IP).
# CORS_ORIGINS=http://localhost:8081,http://192.168.1.10:8081

# Logs JSON por peticiÃ³n (stdout + logs/api-YYYY-MM-DD.log). false para desactivar archivo.
# STRUCTURED_LOGS=true
# LOG_DIR=logs

# Identidad del restaurante (tickets, correo, login).
# RESTAURANT_NAME="Mi Restaurante"
# RESTAURANT_TICKET_PHONE="300 000 0000"
# RESTAURANT_TICKET_ADDRESS="Calle 1 # 2-3"
# RESTAURANT_EMAIL_DOMAIN="drewrest.local"
# Carpeta con logo.png para tickets y app (por defecto: images/ junto al API).
# RESTAURANT_IMAGES_DIR="C:\ruta\images"

# Tope del cuerpo JSON (DoS por payload grande). Ej: 256kb, 1mb.
# BODY_LIMIT=256kb
# Timeout de sockets HTTP por peticiÃ³n (ms, entre 5000 y 120000). Por defecto 30000.
# REQUEST_TIMEOUT_MS=30000

# ProducciÃ³n en el PC del restaurante: licencia obligatoria (archivo api\license.key).
NODE_ENV=production
# Solo en desarrollo en tu PC de programaciÃ³n (omite la licencia):
LICENSE_SKIP=true
# Forzar licencia aunque no sea production:
# LICENSE_ENFORCE=true

# API HTTP + Socket.IO. 0.0.0.0 = aceptar conexiones desde la red local (celulares vÃ­a IP del PC).
PORT=3000
HOST="0.0.0.0"

# Impresora POS 58 mm (ESC/POS, ej. Jaltech 58M) en el PC del restaurante.
PRINTER_ENABLED=true
# Varios destinos separados por coma (prueba en orden). Ejemplos:
#   printer:POS-58              â€” impresora USB por nombre en Windows
#   COM3                        â€” Bluetooth emparejado (puerto serie)
PRINTER_INTERFACE=printer:POS-58,COM3
PRINTER_WIDTH=32
PRINTER_BAUD_RATE=9600
# Encabezado del ticket (logo en carpeta images/logo.png). Ancho Ãºtil 58 mm â‰ˆ 384 px.
# PRINTER_LOGO_WIDTH_PX=384
# PRINTER_LOGO_HEIGHT_FRAC=1
# Puerto de la app web empaquetada (spa-server). En dev Expo suele ser 8081; el QR lo detecta solo.
# WEB_PORT=8080

# EnvÃ­o de factura/recibo por correo (requiere internet en el PC del API hacia el SMTP).
# No es factura electrÃ³nica DIAN; es el comprobante del restaurante en HTML/texto.
# FACTURA_EMAIL_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-clave-de-aplicacion
# SMTP_FROM="DrewRest <tu-correo@gmail.com>"
DATABASE_URL_EXTERNAL_BACKUP="postgresql://postgres:root@localhost:5432/DrewRest?schema=public"
DREWREST_EMBEDDED_PG=1
