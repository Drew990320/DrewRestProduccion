  montoBaseEfectivo       Decimal  @map("monto_base_efectivo") @db.Decimal(12, 2)
  montoBaseCierreEfectivo Decimal? @map("monto_base_cierre_efectivo") @db.Decimal(12, 2)
  actualizadoEn           DateTime @updatedAt @map("actualizado_en")

  @@unique([idRestaurante, fecha])
  @@index([idRestaurante])
  @@map("caja_diaria")
}

model Inventario {
  idInventario    Int             @id @default(autoincrement()) @map("id_inventario")
  idRestaurante   Int             @default(1) @map("id_restaurante")
  ingrediente     String          @db.VarChar(150)
  cantidadActual  Decimal         @map("cantidad_actual") @db.Decimal(10, 3)
  unidad          String          @db.VarChar(20)
  cantidadMinima  Decimal         @map("cantidad_minima") @db.Decimal(10, 3)
  claseInventario ClaseInventario @default(produccion) @map("clase_inventario")
  /// Overrides de ComportamientoInventario (JSON); el preset viene de claseInventario.
  comportamiento  Json            @default("{}") @map("comportamiento")
  idProducto      Int?            @map("id_producto")
  ubicacion       String?         @db.VarChar(120)
  estadoActivo    String?         @map("estado_activo") @db.VarChar(40)
  costoUnitario   Decimal?        @map("costo_unitario") @db.Decimal(12, 4)
  unidadCompra    String?         @map("unidad_compra") @db.VarChar(20)
  /// 1 unidad_compra = factorCompra × unidad base del artículo.
  factorCompra    Decimal?        @map("factor_compra") @db.Decimal(14, 6)
  restaurante     Restaurante     @relation(fields: [idRestaurante], references: [idRestaurante])
  producto        Producto?       @relation(fields: [idProducto], references: [idProducto], onDelete: SetNull)
  movimientos     MovInventario[]
  lineasReceta    RecetaLinea[]

  @@unique([idRestaurante, ingrediente])
  @@index([idRestaurante, claseInventario])
  @@index([idProducto])
  @@map("inventario")
}

model MovInventario {
  idMov           Int               @id @default(autoincrement()) @map("id_mov")
