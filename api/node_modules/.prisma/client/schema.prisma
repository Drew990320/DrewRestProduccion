  idPedido        Int?              @map("id_pedido")
  idDetallePedido Int?              @map("id_detalle_pedido")
  idUsuario       Int?              @map("id_usuario")
  tipoMov         TipoMovInventario @map("tipo_mov")
  cantidad        Decimal           @db.Decimal(10, 3)
  fecha           DateTime          @default(now())
  observacion     String?           @db.Text
  moduloOrigen    String?           @map("modulo_origen") @db.VarChar(40)
  idDocumento     String?           @map("id_documento") @db.VarChar(64)
  costoUnitario   Decimal?          @map("costo_unitario") @db.Decimal(12, 4)
  costoTotal      Decimal?          @map("costo_total") @db.Decimal(12, 2)
  inventario      Inventario        @relation(fields: [idInventario], references: [idInventario])
  pedido          Pedido?           @relation(fields: [idPedido], references: [idPedido])
  usuario         Usuario?          @relation(fields: [idUsuario], references: [idUsuario], onDelete: SetNull)

  @@index([idInventario, fecha])
