generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoMesa {
  libre
  ocupada
  reservada
}

enum EstadoPedido {
  abierto
  en_cocina
  facturado
}

enum TipoPersonalizacion {
  omitir_ingrediente
  aderezo
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
  fiado
}

enum MetodoDevolucionExceso {
  efectivo
  transferencia
}

enum TipoMovimientoCaja {
  devolucion_exceso_transferencia
  entrada_manual
  salida_manual
  pago_domicilio
  pago_mesero
}

enum TipoRegistroBeneficioMesero {
  soda_almuerzo
  pago_turno
}

enum EstadoCredito {
  abierto
  pagado
}

enum TipoMovInventario {
  entrada
  consumo
  ajuste
  compra
  venta
  produccion
  consumo_receta
  consumo_manual
  ajuste_manual
  perdida
  dano
  vencimiento
  transferencia
  devolucion
  inventario_fisico
  prestamo
  reposicion
  mantenimiento
}

enum ClaseInventario {
  comercial
  produccion
  activo_interno
  consumible_interno
}

enum EventoDeduccionInventario {
  al_crear_pedido
  al_confirmar_pedido
  cocina_acepta
  cocina_en_preparacion
  cocina_listo
  al_facturar
  al_entregar
}

enum EstadoRecurso {
  activo
  agotado
  mantenimiento
  baja
  prestado
}

enum TipoMovimientoRecurso {
  compra
  consumo
  venta
  produccion
  transferencia
  ajuste
  devolucion
  perdida
  dano
  robo
  mantenimiento
  baja
  consumo_receta
}

enum EstadoCuentaPorPagar {
  abierta
  pagada
  anulada
}

enum MetodoPagoProveedor {
  efectivo
  transferencia
}

enum ModoServicio {
  en_mesa
  para_llevar
}

enum TipoProteina {
  ninguno
  pollo
  res
  cerdo
  pescado
  vegetariano
  otro
}

enum PrioridadCocinaModo {
  fifo
  por_reglas
  solo_manual

  @@map("prioridad_cocina_modo")
}

enum PrioridadCocina {
  alta
  baja
}

enum TipoEventoPedido {
  detalle_agregado
  detalle_eliminado
  cantidad_actualizada
  /// Precio unitario de una línea ajustado en cobro (no altera el menú).
  precio_unitario_actualizado
  pendiente_anulado_cierre
  cuota_plan_omitida
  cobro_reabierto
  /// Anula una sola tanda (factura o grupo mixto), no todos los cobros del pedido.
  cobro_tanda_revertida
}

enum TipoDelegacionMesero {
  cierre_con_anulacion
}

/// Tenant SaaS: un restaurante por fila. On-prem usa id = 1 (slug `principal`).
model Restaurante {
  idRestaurante Int       @id @default(autoincrement()) @map("id_restaurante")
  slug          String    @unique @db.VarChar(80)
  nombre        String    @db.VarChar(120)
  activo        Boolean   @default(true)
  /// Si está definido y ya pasó, nadie (salvo superadmin) puede iniciar sesión.
  accesoHasta   DateTime? @map("acceso_hasta")
  plan          String    @default("core") @db.VarChar(40)
  creadoEn      DateTime  @default(now()) @map("creado_en")

  usuarios                  Usuario[]
  categorias                Categoria[]
  mesas                     Mesa[]
  pedidos                   Pedido[]
  configRestaurante         ConfigRestaurante?
  lugaresMesa               LugarMesa[]
  configOperativa           ConfigOperativa?
  configDescuento           ConfigDescuento?
  configVisual              ConfigVisual?
  permisosChef              PermisosChefConfig?
  permisosMesero            PermisosMeseroConfig?
  proveedores               Proveedor[]
  configInventario          ConfigInventario?
  inventario                Inventario[]
  conversionesUnidad        ConversionUnidad[]
  recetas                   RecetaProducto[]
  impresorasPos             ImpresoraPos[]
  categoriasRecurso         CategoriaRecurso[]
  ubicacionesRecurso        UbicacionRecurso[]
  recursos                  Recurso[]
  configContabilidad        ConfigContabilidad?
  categoriasContablesSimple CategoriaContableSimple[]
  reglasContables           ReglaContable[]
  asientosContables         AsientoContable[]
  centrosCosto              CentroCosto[]

  @@map("restaurante")
}

enum RolImpresoraPos {
  cocina
  factura
  caja
}

enum AlcanceReglaImpresion {
  categoria
  producto
}

/// Impresoras POS térmicas (Windows spooler o COM) con roles de ticket.
model ImpresoraPos {
  idImpresora     Int                    @id @default(autoincrement()) @map("id_impresora")
  idRestaurante   Int                    @default(1) @map("id_restaurante")
  nombre          String                 @db.VarChar(120)
  /// Destino ESC/POS: printer:NombreWindows | COM3 | \\.\COM4
  destino         String                 @db.VarChar(200)
  activa          Boolean                @default(true)
  orden           Int                    @default(0)
  baudRate        Int?                   @map("baud_rate")
  /// Ancho del rollo térmico: 58 o 80 (mm). Define chars/línea y logo.
  anchoPapelMm    Int                    @default(58) @map("ancho_papel_mm")
  roles           RolImpresoraPos[]
  /// Si true y tiene rol cocina: imprime comanda completa (además de estaciones filtradas).
  esCocinaMaestra Boolean                @default(false) @map("es_cocina_maestra")
  creadoEn        DateTime               @default(now()) @map("creado_en")
  actualizadoEn   DateTime               @updatedAt @map("actualizado_en")
  restaurante     Restaurante            @relation(fields: [idRestaurante], references: [idRestaurante])
  reglasCocina    ReglaImpresionCocina[]

  @@unique([idRestaurante, destino])
  @@index([idRestaurante, activa, orden])
  @@map("impresora_pos")
}

/// Enruta líneas de comanda a una estación (categoría o producto del menú).
model ReglaImpresionCocina {
  idRegla     Int                   @id @default(autoincrement()) @map("id_regla")
  idImpresora Int                   @map("id_impresora")
  alcance     AlcanceReglaImpresion
  idCategoria Int?                  @map("id_categoria")
  idProducto  Int?                  @map("id_producto")
  orden       Int                   @default(0)
  impresora   ImpresoraPos          @relation(fields: [idImpresora], references: [idImpresora], onDelete: Cascade)
  categoria   Categoria?            @relation(fields: [idCategoria], references: [idCategoria], onDelete: Cascade)
  producto    Producto?             @relation(fields: [idProducto], references: [idProducto], onDelete: Cascade)

  @@index([idImpresora, orden])
  @@index([idCategoria])
  @@index([idProducto])
  @@map("regla_impresion_cocina")
}

model Rol {
  idRol       Int       @id @default(autoincrement()) @map("id_rol")
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  usuarios    Usuario[]

  @@map("rol")
}

model Usuario {
  idUsuario                     Int                       @id @default(autoincrement()) @map("id_usuario")
  idRestaurante                 Int                       @default(1) @map("id_restaurante")
  idRol                         Int                       @map("id_rol")
  nombre                        String                    @db.VarChar(100)
  apellido                      String                    @db.VarChar(100)
  email                         String                    @db.VarChar(150)
  passwordHash                  String                    @map("password_hash") @db.VarChar(255)
  passwordCambiadoEn            DateTime?                 @map("password_cambiado_en")
  activo                        Boolean                   @default(true)
  creadoEn                      DateTime                  @default(now()) @map("creado_en")
  rol                           Rol                       @relation(fields: [idRol], references: [idRol])
  restaurante                   Restaurante               @relation(fields: [idRestaurante], references: [idRestaurante])
  pedidos                       Pedido[]
  facturas                      Factura[]
  historialPedidos              PedidoHistorial[]
  beneficiosMesero              RegistroBeneficioMesero[] @relation("BeneficioMesero")
  beneficiosRegistrados         RegistroBeneficioMesero[] @relation("BeneficioRegistradoPor")
  delegacionesMeseroTurno       DelegacionMeseroTurno[]   @relation("DelegacionMesero")
  delegacionesMeseroRegistradas DelegacionMeseroTurno[]   @relation("DelegacionRegistradaPor")
  movimientosCaja               MovimientoCaja[]
  cuentasCredito                CuentaCredito[]
  cuentasPorPagar               CuentaPorPagar[]
  pagosProveedor                PagoProveedor[]
  movimientosInventario         MovInventario[]
  recursosResponsable           Recurso[]                 @relation("RecursoResponsable")
  movimientosRecurso            MovimientoRecurso[]
  mantenimientosRecurso         MantenimientoRecurso[]
  asientosContables             AsientoContable[]

  @@unique([idRestaurante, email])
  @@index([idRestaurante])
  @@map("usuario")
}

model LugarMesa {
  idLugar       Int         @id @default(autoincrement()) @map("id_lugar")
  idRestaurante Int         @default(1) @map("id_restaurante")
  nombre        String      @db.VarChar(100)
  orden         Int         @default(1)
  activo        Boolean     @default(true)
  creadoEn      DateTime    @default(now()) @map("creado_en")
  restaurante   Restaurante @relation(fields: [idRestaurante], references: [idRestaurante])
  mesas         Mesa[]

  @@index([idRestaurante, activo, orden])
  @@map("lugar_mesa")
}

model Mesa {
  idMesa              Int               @id @default(autoincrement()) @map("id_mesa")
  idRestaurante       Int               @default(1) @map("id_restaurante")
  idLugar             Int?              @map("id_lugar")
  numero              Int
  capacidad           Int
  estado              EstadoMesa        @default(libre)
  disponibleLunes     Boolean           @default(true) @map("disponible_lunes")
  disponibleMartes    Boolean           @default(true) @map("disponible_martes")
  disponibleMiercoles Boolean           @default(true) @map("disponible_miercoles")
  disponibleJueves    Boolean           @default(true) @map("disponible_jueves")
  disponibleViernes   Boolean           @default(true) @map("disponible_viernes")
  disponibleSabado    Boolean           @default(true) @map("disponible_sabado")
  disponibleDomingo   Boolean           @default(true) @map("disponible_domingo")
  restaurante         Restaurante       @relation(fields: [idRestaurante], references: [idRestaurante])
  lugar               LugarMesa?        @relation(fields: [idLugar], references: [idLugar], onDelete: SetNull)
  pedidos             Pedido[]
  pedidosAnexos       PedidoMesaAnexa[]

  @@unique([idRestaurante, numero])
  @@index([idRestaurante])
  @@index([idLugar, numero])
  @@map("mesa")
}

enum TipoLineaCocinaCat {
  plato
  entrada
  adicional

  @@map("tipo_linea_cocina_cat")
}

model Categoria {
  idCategoria             Int                    @id @default(autoincrement()) @map("id_categoria")
  idRestaurante           Int                    @default(1) @map("id_restaurante")
  nombre                  String                 @db.VarChar(100)
  disponibleLunes         Boolean                @default(true) @map("disponible_lunes")
  disponibleMartes        Boolean                @default(true) @map("disponible_martes")
  disponibleMiercoles     Boolean                @default(true) @map("disponible_miercoles")
  disponibleJueves        Boolean                @default(true) @map("disponible_jueves")
  disponibleViernes       Boolean                @default(true) @map("disponible_viernes")
  disponibleSabado        Boolean                @default(true) @map("disponible_sabado")
  disponibleDomingo       Boolean                @default(true) @map("disponible_domingo")
  esBebida                Boolean                @default(false) @map("es_bebida")
  cobraEmpaqueParaLlevar  Boolean                @default(false) @map("cobra_empaque_para_llevar")
  participaDescuentoSopas Boolean                @default(false) @map("participa_descuento_sopas")
  esLineaEmpaque          Boolean                @default(false) @map("es_linea_empaque")
  visibleEnMostrador      Boolean                @default(false) @map("visible_en_mostrador")
  tipoLineaCocinaDefault  TipoLineaCocinaCat     @default(plato) @map("tipo_linea_cocina_default")
  esPlatoPrincipalDefault Boolean                @default(false) @map("es_plato_principal_default")
  /// Si true, los platos principales de esta categoría bajan la prioridad en cocina (modo por_reglas).
  prioridadCocinaBaja     Boolean                @default(false) @map("prioridad_cocina_baja")
  /// Icono Material Community para la barra de categorías del menú (null = inferir por nombre).
  iconoMenu               String?                @map("icono_menu") @db.VarChar(80)
  /// Oculta toda la categoría del menú (reversible); los días definen visibilidad cuando está activa.
  activo                  Boolean                @default(true)
  restaurante             Restaurante            @relation(fields: [idRestaurante], references: [idRestaurante])
  productos               Producto[]
  reglasImpresionCocina   ReglaImpresionCocina[]

  @@unique([idRestaurante, nombre])
  @@index([idRestaurante])
  @@map("categoria")
}

model Producto {
  idProducto                    Int                       @id @default(autoincrement()) @map("id_producto")
  idCategoria                   Int                       @map("id_categoria")
  nombre                        String                    @db.VarChar(150)
  descripcion                   String?                   @db.Text
  precio                        Decimal                   @db.Decimal(10, 2)
  activo                        Boolean                   @default(true)
  esPlatoPrincipal              Boolean                   @default(false) @map("es_plato_principal")
  esEmpacable                   Boolean                   @default(false) @map("es_empacable")
  enviaCocina                   Boolean                   @default(true) @map("envia_cocina")
  usaSubitemsRepartibles        Boolean                   @default(false) @map("usa_subitems_repartibles")
  /// Unidades a repartir entre subítems al tomar el pedido (solo si usa subítems repartibles).
  cantidadRepartoSubitems       Int                       @default(1) @map("cantidad_reparto_subitems")
  /// Línea automática de cocina: 1 por comensal, sin cobro (no aparece en menú).
  esAcompanamientoMazorca       Boolean                   @default(false) @map("es_acompanamiento_mazorca")
  /// Línea cobrable por cuota omitida en reparto (no menú, no cocina).
  esCuotaPendienteReparto       Boolean                   @default(false) @map("es_cuota_pendiente_reparto")
  tipoProteina                  TipoProteina              @default(ninguno) @map("tipo_proteina")
  /// null = heredar categoría; true/false = override de prioridad baja en cocina.
  prioridadCocinaBaja           Boolean?                  @map("prioridad_cocina_baja")
  /// Solo aplica en categorías bebida: control de unidades pedibles.
  controlStock                  Boolean                   @default(false) @map("control_stock")
  stockDisponible               Int                       @default(0) @map("stock_disponible")
  /// Si true, no aparece en menú al llegar a 0; si false, se muestra como agotado.
  ocultarSinStock               Boolean                   @default(true) @map("ocultar_sin_stock")
  categoria                     Categoria                 @relation(fields: [idCategoria], references: [idCategoria])
  detalles                      DetallePedido[]
  opciones                      PersonalizacionOpcion[]
  subitems                      ProductoSubitem[]
  configOperativaMazorca        ConfigOperativa[]         @relation("ProductoMazorcaConfig")
  configOperativaSoda           ConfigOperativa[]         @relation("ProductoSodaAlmuerzoConfig")
  configOperativaCuotaPendiente ConfigOperativa[]         @relation("ProductoCuotaPendienteConfig")
  registrosBeneficioMesero      RegistroBeneficioMesero[]
  inventarioItems               Inventario[]
  recursos                      Recurso[]
  receta                        RecetaProducto?
  reglasImpresionCocina         ReglaImpresionCocina[]

  @@map("producto")
}

model PersonalizacionOpcion {
  idOpcion    Int                  @id @default(autoincrement()) @map("id_opcion")
  idProducto  Int                  @map("id_producto")
  tipo        TipoPersonalizacion
  descripcion String               @db.VarChar(150)
  producto    Producto             @relation(fields: [idProducto], references: [idProducto], onDelete: Cascade)
  detPers     DetPersonalizacion[]

  @@index([idProducto])
  @@map("personalizacion_opcion")
}

model ProductoSubitem {
  idSubitem  Int                  @id @default(autoincrement()) @map("id_subitem")
  idProducto Int                  @map("id_producto")
  nombre     String               @db.VarChar(150)
  activo     Boolean              @default(true)
  orden      Int                  @default(0)
  producto   Producto             @relation(fields: [idProducto], references: [idProducto], onDelete: Cascade)
  cantidades DetSubitemCantidad[]

  @@index([idProducto, activo, orden])
  @@map("producto_subitem")
}

model Pedido {
  idPedido                Int                 @id @default(autoincrement()) @map("id_pedido")
  idRestaurante           Int                 @default(1) @map("id_restaurante")
  idMesa                  Int                 @map("id_mesa")
  idUsuario               Int                 @map("id_usuario")
  estado                  EstadoPedido        @default(abierto)
  modoServicio            ModoServicio        @default(en_mesa) @map("modo_servicio")
  numComensales           Int                 @map("num_comensales")
  creadoEn                DateTime            @default(now()) @map("creado_en")
  cerradoEn               DateTime?           @map("cerrado_en")
  prioridadCocinaOverride PrioridadCocina?    @map("prioridad_cocina_override")
  /// Cliente camionero (mulero): aplica descuento por plato principal si la regla global está activa.
  clienteMulero           Boolean             @default(false) @map("cliente_mulero")
  /// Etiquetas de promoción activas en el pedido (ids del catálogo en config_descuento).
  etiquetasPromocion      Json                @default("[]") @map("etiquetas_promocion")
  mesa                    Mesa                @relation(fields: [idMesa], references: [idMesa])
  usuario                 Usuario             @relation(fields: [idUsuario], references: [idUsuario])
  restaurante             Restaurante         @relation(fields: [idRestaurante], references: [idRestaurante])
  detalles                DetallePedido[]
  facturas                Factura[]
  movimientosCaja         MovimientoCaja[]
  movsInventario          MovInventario[]
  movimientosRecurso      MovimientoRecurso[]
  historial               PedidoHistorial[]
  cuentasCredito          CuentaCredito[]
  mesasAnexas             PedidoMesaAnexa[]

  @@index([idRestaurante, estado, creadoEn])
  @@index([idMesa, estado])
  @@index([estado, creadoEn])
  @@index([idUsuario, estado])
  @@map("pedido")
}

/// Mesas físicas adicionales ligadas al mismo pedido (mesa principal en pedido.id_mesa).
model PedidoMesaAnexa {
  idPedidoMesaAnexa Int      @id @default(autoincrement()) @map("id_pedido_mesa_anexa")
  idPedido          Int      @map("id_pedido")
  idMesa            Int      @unique @map("id_mesa")
  creadoEn          DateTime @default(now()) @map("creado_en")
  pedido            Pedido   @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  mesa              Mesa     @relation(fields: [idMesa], references: [idMesa], onDelete: Restrict)

  @@unique([idPedido, idMesa])
  @@index([idPedido])
  @@map("pedido_mesa_anexa")
}

// detalleJson: líneas afectadas, cantidades, nombres (estructura por tipo de evento).
model PedidoHistorial {
  idHistorial Int              @id @default(autoincrement()) @map("id_historial")
  idPedido    Int              @map("id_pedido")
  idUsuario   Int              @map("id_usuario")
  tipo        TipoEventoPedido
  detalleJson Json?            @map("detalle_json")
  creadoEn    DateTime         @default(now()) @map("creado_en")
  pedido      Pedido           @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  usuario     Usuario          @relation(fields: [idUsuario], references: [idUsuario])

  @@index([idPedido])
  @@map("pedido_historial")
}

model DetallePedido {
  idDetalle         Int                  @id @default(autoincrement()) @map("id_detalle")
  idPedido          Int                  @map("id_pedido")
  idProducto        Int                  @map("id_producto")
  idDetallePadre    Int?                 @map("id_detalle_padre")
  cantidad          Int                  @default(1)
  precioUnitario    Decimal              @map("precio_unitario") @db.Decimal(10, 2)
  notaCocina        String?              @map("nota_cocina") @db.Text
  listoCocina       Boolean              @default(false) @map("listo_cocina")
  listoParaRecoger  Boolean              @default(false) @map("listo_para_recoger")
  enviadoCocina     Boolean              @default(false) @map("enviado_cocina")
  enviadoCocinaEn   DateTime?            @map("enviado_cocina_en")
  idFactura         Int?                 @map("id_factura")
  pedido            Pedido               @relation(fields: [idPedido], references: [idPedido], onDelete: Cascade)
  producto          Producto             @relation(fields: [idProducto], references: [idProducto])
  detallePadre      DetallePedido?       @relation("DetalleEmpaque", fields: [idDetallePadre], references: [idDetalle], onDelete: Cascade)
  empaquesAsociados DetallePedido[]      @relation("DetalleEmpaque")
  personalizaciones DetPersonalizacion[]
  subitems          DetSubitemCantidad[]
  factura           Factura?             @relation(fields: [idFactura], references: [idFactura])

  @@index([idPedido])
  @@index([idDetallePadre])
  @@index([idFactura])
  @@map("detalle_pedido")
}

model DetPersonalizacion {
  idDetPers Int                   @id @default(autoincrement()) @map("id_det_pers")
  idDetalle Int                   @map("id_detalle")
  idOpcion  Int                   @map("id_opcion")
  detalle   DetallePedido         @relation(fields: [idDetalle], references: [idDetalle], onDelete: Cascade)
  opcion    PersonalizacionOpcion @relation(fields: [idOpcion], references: [idOpcion])

  @@index([idDetalle])
  @@map("det_personalizacion")
}

model DetSubitemCantidad {
  idDetSubitem Int             @id @default(autoincrement()) @map("id_det_subitem")
  idDetalle    Int             @map("id_detalle")
  idSubitem    Int             @map("id_subitem")
  cantidad     Int
  detalle      DetallePedido   @relation(fields: [idDetalle], references: [idDetalle], onDelete: Cascade)
  subitem      ProductoSubitem @relation(fields: [idSubitem], references: [idSubitem], onDelete: Restrict)

  @@unique([idDetalle, idSubitem])
  @@index([idDetalle])
  @@index([idSubitem])
  @@map("det_subitem_cantidad")
}

model Factura {
  idFactura                   Int              @id @default(autoincrement()) @map("id_factura")
  idPedido                    Int              @map("id_pedido")
  idUsuario                   Int              @map("id_usuario")
  subtotal                    Decimal          @db.Decimal(10, 2)
  descuentoSopas              Decimal          @default(0) @map("descuento_sopas") @db.Decimal(10, 2)
  descuentoMuleros            Decimal          @default(0) @map("descuento_muleros") @db.Decimal(10, 2)
  descuentoPromociones        Decimal          @default(0) @map("descuento_promociones") @db.Decimal(10, 2)
  total                       Decimal          @db.Decimal(10, 2)
  metodoPago                  MetodoPago       @map("metodo_pago")
  emitidaEn                   DateTime         @default(now()) @map("emitida_en")
  esParcial                   Boolean          @default(false) @map("es_parcial")
  /// Persona del plan de cobro (1-based); varias facturas pueden compartir índice (pago mixto).
  personaPlanIndice           Int?             @map("persona_plan_indice")
  /// true = cuota sobre el total (modo por personas); false = ítems asignados (combinado/platos).
  planPersonasSobreTotal      Boolean          @default(false) @map("plan_personas_sobre_total")
  /// true = cuota sobre ítems marcados (+/−) en modo combinado; ticket muestra selección como referencia.
  planCombinadoSobreSeleccion Boolean          @default(false) @map("plan_combinado_sobre_seleccion")
  /// Snapshot [{id_detalle,cantidad}] de la selección combinada (referencia en ticket).
  planSeleccionReferencia     Json?            @map("plan_seleccion_referencia")
  /// Identificador común de un cobro mixto (efectivo + transferencia en la misma operación).
  cobroMixtoGrupo             Int?             @map("cobro_mixto_grupo")
  /// Vuelto / exceso de cobro (efectivo, transferencia, domicilio, mesero).
  detalleExcesoCobro          Json?            @map("detalle_exceso_cobro")
  pedido                      Pedido           @relation(fields: [idPedido], references: [idPedido])
  usuario                     Usuario          @relation(fields: [idUsuario], references: [idUsuario])
  detalles                    DetallePedido[]
  movimientosCaja             MovimientoCaja[]
  cuentaCredito               CuentaCredito?

  @@index([idPedido])
  @@index([emitidaEn])
  @@map("factura")
}

