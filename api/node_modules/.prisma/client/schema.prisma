}

/// Política de deducción automática por tenant (genérica, configurable en BD).
model ConfigInventario {
  idRestaurante             Int                        @id @map("id_restaurante")
  eventoDeduccionReceta     EventoDeduccionInventario  @default(cocina_en_preparacion) @map("evento_deduccion_receta")
  eventoDeduccionComercial  EventoDeduccionInventario  @default(al_crear_pedido) @map("evento_deduccion_comercial")
  eventoDeduccionConsumible EventoDeduccionInventario? @map("evento_deduccion_consumible")
  actualizadoEn             DateTime                   @updatedAt @map("actualizado_en")
