DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/restaurant_pos?schema=public"
# Base de datos aislada para e2e (opcional). Si no se define, se usa DATABASE_URL.
# DATABASE_URL_TEST="postgresql://USER:PASSWORD@localhost:5432/restaurant_pos_test?schema=public"
# Omitir e2e en local: SKIP_E2E=true
# En CI (GitHub Actions) se usa PostgreSQL en contenedor; ver .github/workflows/api-ci.yml
# Límite de conexiones Prisma (por defecto 10 si no se define; útil con varios tablets).
# DATABASE_CONNECTION_LIMIT=10
JWT_SECRET="cambiar-por-secreto-largo-en-produccion"
# Duración del access token (por defecto 24h). Ej: 12h, 7d
# JWT_EXPIRES_IN=24h

# SaaS: clave para POST /platform/restaurantes (alta de tenants). Vacío = deshabilitado.
# PLATFORM_PROVISION_KEY="genera-un-secreto-largo"

# App móvil SaaS: EXPO_PUBLIC_MULTI_TENANT=1 muestra campo "código del restaurante" en login.

# Orígenes CORS permitidos (coma-separados). Vacío = LAN abierta (tablets por IP).
# CORS_ORIGINS=http://localhost:8081,http://192.168.1.10:8081

# Logs JSON por petición (stdout + logs/api-YYYY-MM-DD.log). false para desactivar archivo.
# STRUCTURED_LOGS=true
# LOG_DIR=logs

# Identidad del restaurante (tickets, correo, login).
# RESTAURANT_NAME="Mi Restaurante"
# RESTAURANT_TICKET_PHONE="300 000 0000"
# RESTAURANT_TICKET_ADDRESS="Calle 1 # 2-3"
# RESTAURANT_EMAIL_DOMAIN="drewrest.local"
# Carpeta con logo.png para tickets y app (por defecto: images/ junto al API).
# RESTAURANT_IMAGES_DIR="C:\ruta\images"

# Tope del cuerpo JSON (DoS por payload grande). Ej: 256kb, 1mb.
# BODY_LIMIT=256kb
# Timeout de sockets HTTP por petición (ms, entre 5000 y 120000). Por defecto 30000.
# REQUEST_TIMEOUT_MS=30000

# Producción en el PC del restaurante: licencia obligatoria (archivo api\license.key).
NODE_ENV=production
# Solo en desarrollo en tu PC de programación (omite la licencia):
# LICENSE_SKIP=true
# Forzar licencia aunque no sea production:
# LICENSE_ENFORCE=true

# API HTTP + Socket.IO. 0.0.0.0 = aceptar conexiones desde la red local (celulares vía IP del PC).
PORT=3000
HOST=0.0.0.0

# Impresora POS 58 mm (ESC/POS, ej. Jaltech 58M) en el PC del restaurante.
PRINTER_ENABLED=true
# Vista previa PDF 58 mm (demo cloud / sin impresora). En LAN con impresora: false.
# TICKET_PREVIEW_ENABLED=false
# Varios destinos separados por coma (prueba en orden). Ejemplos:
#   printer:POS-58              — impresora USB por nombre en Windows
#   COM3                        — Bluetooth emparejado (puerto serie)
PRINTER_INTERFACE=printer:POS-58,COM3
PRINTER_WIDTH=32
PRINTER_BAUD_RATE=9600
# Encabezado del ticket (logo en carpeta images/logo.png). Ancho útil 58 mm ≈ 384 px.
# PRINTER_LOGO_WIDTH_PX=384
# PRINTER_LOGO_HEIGHT_FRAC=1
# Puerto de la app web empaquetada (spa-server). En dev Expo suele ser 8081; el QR lo detecta solo.
# WEB_PORT=8080

# Envío de factura/recibo por correo (requiere internet en el PC del API hacia el SMTP).
# No es factura electrónica DIAN; es el comprobante del restaurante en HTML/texto.
# FACTURA_EMAIL_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-clave-de-aplicacion
# SMTP_FROM="DrewRest <tu-correo@gmail.com>"
