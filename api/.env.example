# DrewRest on-prem — por defecto usa PostgreSQL embebido (DrewRest.exe).
# Si usas Postgres del sistema, cambia DATABASE_URL y pon DREWREST_EMBEDDED_PG=0.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5433/DrewRest?schema=public"
DREWREST_EMBEDDED_PG=1
JWT_SECRET="drewrest-cambiar-en-produccion"
# En restaurante: licencia obligatoria (api\license.key). NO pongas LICENSE_SKIP aquí.
NODE_ENV=production
# Solo en tu PC de programación (lab):
# LICENSE_SKIP=true
PORT=3000
HOST=0.0.0.0
PRINTER_ENABLED=false
# Puerto web preferido. Si 8080 esta ocupado, el launcher busca el siguiente libre (salta 8081 = Expo).
# WEB_PORT=8080
# WEB_PORT_SKIP=8081
